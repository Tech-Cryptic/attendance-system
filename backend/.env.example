# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ── Security ──────────────────────────────────────────────────
# Generate strong secrets with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
HMAC_KEY=REPLACE_WITH_STRONG_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────
# Set to your Vercel frontend URL after deployment
# Multiple origins: comma-separated, no spaces
CORS_ORIGINS=https://YOUR-APP.vercel.app
