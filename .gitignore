# FaceAttend — root .gitignore

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Python backend ────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/.env
backend/*.egg-info/

# ── Node / Frontend ───────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dev-dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ── Secrets (never commit these) ─────────────────────────
*.pem
*.key
.env
.env.local
.env.production
